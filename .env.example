# ============================================================
# .env.example — Variáveis de ambiente do Bot Financeiro
#
# INSTRUÇÕES:
#   1. Copie este arquivo para .env
#      cp .env.example .env
#
#   2. Preencha os valores abaixo
#
#   3. NUNCA versione o arquivo .env no Git
#      (já está no .gitignore)
# ============================================================


# Token do BotFather
TELEGRAM_TOKEN=SEU_TOKEN_AQUI

# Seu user_id do Telegram (descubra com @userinfobot)
# Apenas você terá acesso automático como administrador
TELEGRAM_ADMIN_ID=SEU_ID_AQUI
